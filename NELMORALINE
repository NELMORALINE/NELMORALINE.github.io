<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NELMORA | Luxury Bags</title>

<style>
body {
  margin: 0;
  font-family: Arial, sans-serif;
  background: #0a0a0a;
  color: #fff;
}

header {
  background: #000;
  padding: 20px;
  text-align: center;
  border-bottom: 1px solid gold;
}

header h1 {
  color: gold;
  letter-spacing: 3px;
}

.hero {
  text-align: center;
  padding: 80px 20px;
}

.hero h2 {
  font-size: 40px;
  color: gold;
}

.hero p {
  color: #ccc;
}

.products {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px,1fr));
  gap: 20px;
  padding: 40px;
}

.product {
  background: #111;
  padding: 20px;
  border: 1px solid #222;
  text-align: center;
  transition: 0.3s;
}

.product:hover {
  border-color: gold;
  transform: scale(1.05);
}

.product img {
  width: 100%;
  height: 250px;
  object-fit: cover;
}

.price {
  color: gold;
  font-weight: bold;
}

button {
  background: gold;
  border: none;
  padding: 10px 20px;
  margin-top: 10px;
  cursor: pointer;
}

footer {
  text-align: center;
  padding: 20px;
  border-top: 1px solid gold;
  margin-top: 40px;
}
</style>
</head>

<body>

<header>
  <h1>NELMORA</h1>
  <p>Luxury Bags Collection</p>
</header>

<section class="hero">
  <h2>Elegance in Every Detail</h2>
  <p>Premium handbags crafted for modern women in Morocco</p>
</section>

<section class="products">

<div class="product">
  <img src="https://images.unsplash.com/photo-1584917865442-de89df76afd3">
  <h3>Elegant Handbag</h3>
  <p class="price">490 MAD</p>
  <button>Order Now</button>
</div>

<div class="product">
  <img src="https://images.unsplash.com/photo-1591561954557-26941169b49e">
  <h3>Luxury Tote Bag</h3>
  <p class="price">790 MAD</p>
  <button>Order Now</button>
</div>

<div class="product">
  <img src="https://images.unsplash.com/photo-1600185365926-3a2ce3cdb9eb">
  <h3>Premium Crossbody</h3>
  <p class="price">690 MAD</p>
  <button>Order Now</button>
</div>

</section>

<footer>
  <p>Delivery all over Morocco | Cash on Delivery Available</p>
  <p>© 2026 NELMORA</p>
</footer>

</body>
</html>
